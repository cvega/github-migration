{
  "name": "gh-migrate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun svelte-kit sync && bunx --bun vite build && bun scripts/postbuild.ts",
    "preview": "bunx --bun vite preview",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
    "ci": "bun run check && bun run build",
    "format": "bunx --bun biome format --write .",
    "lint": "bunx --bun biome lint .",
    "seed": "bun scripts/seed.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@primer/octicons": "^19.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@sveltejs/adapter-node": "^5.5.3",
    "@sveltejs/kit": "^2.51.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.9",
    "@types/primer__octicons": "^19.21.0",
    "svelte": "^5.51.1",
    "svelte-check": "^4.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
