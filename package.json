{
  "name": "gh-migrate",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun svelte-kit sync && bunx --bun vite build && bun scripts/postbuild.ts",
    "preview": "bunx --bun vite preview",
    "prepare": "svelte-kit sync || true",
    "typecheck": "bunx --bun svelte-kit sync && bunx --bun tsc --noEmit && bunx --bun tsc --noEmit -p scripts/tsconfig.json",
    "check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint": "bunx --bun biome check --error-on-warnings .",
    "format": "bunx --bun biome format --write .",
    "format:check": "bunx --bun biome format .",
    "test": "bun test",
    "coverage:check": "bun scripts/coverage-check.ts",
    "audit": "bun audit",
    "dup": "jscpd src",
    "deadcode": "knip",
    "cycles": "madge --circular --extensions ts,svelte --ts-config tsconfig.json src",
    "boundaries": "bun scripts/boundaries.ts",
    "mutation": "stryker run",
    "ci": "bun run check && bun run build",
    "seed": "bun scripts/seed.ts",
    "release:prep": "bun scripts/release-prep.ts",
    "verify": "bun run typecheck && bun run check && bun run lint && bun run format:check && bun run coverage:check && bun run dup && bun run deadcode && bun run cycles && bun run boundaries && bun run build && bun run audit",
    "gates": "bun scripts/gates.ts"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@primer/octicons": "^19.28.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@stryker-mutator/core": "^9.6.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "^1.3.14",
    "@types/primer__octicons": "^19.21.0",
    "git-cliff": "^2.13.1",
    "jscpd": "^5.0.9",
    "knip": "^6.16.1",
    "madge": "^8.0.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "cookie": "^0.7.2",
    "qs": "^6.15.2"
  }
}
