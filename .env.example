# gh-migrate environment configuration

# Optional: Basic auth for the web UI
# GH_MIGRATE_USER=admin
# GH_MIGRATE_PASS=changeme

# Optional: Data directory for SQLite database (default: ./data)
# DATA_DIR=./data

# Optional: Directory for temporary archive files during GHES migrations (default: OS temp dir)
# ARCHIVE_DIR=/tmp

# Optional: Port (default: 3000)
# PORT=3000

# Optional: Source GitHub App (avoids per-request PAT tokens)
# GH_SOURCE_APP_ID=12345
# GH_SOURCE_APP_PRIVATE_KEY=base64-encoded-pem
# GH_SOURCE_APP_INSTALLATION_ID=67890
# GH_SOURCE_API_URL=https://ghes.example.com/api/v3

# Optional: Target GitHub App (GHEC side)
# GH_TARGET_APP_ID=12345
# GH_TARGET_APP_PRIVATE_KEY=base64-encoded-pem
# GH_TARGET_APP_INSTALLATION_ID=67890
