# gh-migrate environment configuration

# Optional: Basic auth for the web UI
# GH_MIGRATE_USER=admin
# GH_MIGRATE_PASS=changeme

# Optional: Data directory for SQLite database (default: ./data)
# DATA_DIR=./data

# Optional: Directory for temporary archive files during GHES migrations (default: OS temp dir)
# ARCHIVE_DIR=/tmp

# Optional: Port (default: 3000)
# PORT=3000
